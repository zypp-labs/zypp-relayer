  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/api/index.js",
    "worker": "node dist/worker/index.js",
    "dev:api": "tsx watch src/api/index.ts",
    "dev:worker": "tsx watch src/worker/index.ts",
    "migrate": "tsx src/store/run-migrate.ts",
