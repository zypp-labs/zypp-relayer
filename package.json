    "@supabase/supabase-js": "^2.103.0",
    "bullmq": "^5.25.0",
    "fastify": "^5.1.0",
    "ioredis": "^5.4.1",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "tweetnacl": "^1.0.3",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "bs58": "^6.0.0",
    "eslint": "^9.16.0",
